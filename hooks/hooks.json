{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/session-start.exe",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/session-stop.exe",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mem_save",
        "hooks": [
          {
            "type": "command",
            "command": "echo {\"systemMessage\":\"BOARD CHECK: You just saved something to engram. Does any card on the Cyber Mango board need to be created, updated, or moved to reflect this change? If yes, do it now. If not, carry on.\"}",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
